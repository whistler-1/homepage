RewriteEngine On

# Redirect HTTP to HTTPS (your existing rule)

RewriteCond %{SERVER_PORT} 80
RewriteCond %{HTTP_HOST} ^(www\.)?bwhistler\.no
RewriteRule ^(.\*)$ https://www.bwhistler.no/$1 [R,L]

# SPA fallback: serve index.html for anything that isn't a real file

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.html [L]
